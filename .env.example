# Radar Gestión Valencia - ejemplo de variables locales
# Copiar a .env y rellenar localmente. No subir .env a Git.

# Backend Supabase read-only paralelo
SUPABASE_READONLY_ENABLED=false
SUPABASE_URL=
SUPABASE_SERVER_KEY=

# Portal Cliente - Comunicaciones asesoria-cliente
RADAR_CLIENT_PORTAL_COMMUNICATIONS_ENABLED=false

# Portal Cliente - Documentacion trimestral
RADAR_QUARTERLY_DOCUMENTATION_ENABLED=false
